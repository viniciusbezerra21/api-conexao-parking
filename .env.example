# Configurações do Banco de Dados (Local)
MYSQL_URL=jdbc:mysql://localhost:3306/conexaoparking_api
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha_aqui

# Segurança e Autenticação
# Gere uma string aleatória de pelo menos 32 caracteres para o JWT
JWT_SECRET=coloque_aqui_seu_segredo_de_teste_local

# Perfil Ativo (dev ou prod)
SPRING_PROFILES_ACTIVE=dev

# Configurações de Administrador Inicial
ADMIN_EMAIL=vini@adm.com
ADMIN_PASSWORD=admin123